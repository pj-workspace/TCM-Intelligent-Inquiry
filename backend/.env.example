# 复制为 .env 后填写真实值：cp .env.example .env
#
# 热切换：修改本文件并保存后，下一轮 API 请求会重新读取配置（无需重启 uvicorn）。
# 已支持热切换：LLM_PROVIDER、各厂商 Key/模型、RERANK_*、JWT、API_KEY、MAX_UPLOAD_BYTES、
#   DATABASE_AUTO_CREATE_TABLES、INGEST_TEMP_DIR、CELERY_INGEST_ENABLED、DEFAULT_KNOWLEDGE_BASE_ID 等。
# 若配置 QWEN_CHAT_MODEL_OPTIONS：**必须**为合法单行 JSON；校验失败会导致无法加载 Settings。
# 仍需重启 API 进程：DATABASE_URL（异步引擎在启动时创建）、仅改 Celery worker 的 broker、以及 worker 本身。
#
# 向量嵌入厂商（qwen | openai）；留空则与 LLM_PROVIDER 一致（对话用 anthropic 时仍可单独指定 qwen 嵌入）
# EMBEDDING_PROVIDER=

# ── 对话模型厂商：qwen | openai | anthropic | glm | deepseek ───────────────
LLM_PROVIDER=qwen

# 阿里云 DashScope（通义千问 + 知识库向量嵌入，推荐始终配置）
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 对话模型（DashScope OpenAI 兼容模式下的模型 id）。配置了 QWEN_CHAT_MODEL_OPTIONS 时，
# 须与 OPTIONS 中带 "default": true 的 id 一致（否则会打 warning）。
QWEN_CHAT_MODEL=qwen-flash

# 可选：多模型下拉——单行 JSON 数组（空数组 [] 表示不启用下拉，仅用 QWEN_CHAT_MODEL）。
# 须恰好一项 default:true；每项含 id、label、capabilities（supports_tool_calling / supports_deep_think /
# input 等，省略键默认为 true）。
# QWEN_CHAT_MODEL_OPTIONS=[]
# Flash + VL Plus 示例（取消上一行注释并改用本示例即可）：
# QWEN_CHAT_MODEL_OPTIONS=[{"id":"qwen-flash","label":"Qwen Flash","default":true,"capabilities":{"input":["text"],"supports_tool_calling":true,"supports_deep_think":true}},{"id":"qwen3-vl-plus","label":"Qwen3 VL Plus","default":false,"capabilities":{"input":["text","image","video"],"supports_tool_calling":true,"supports_deep_think":true}}]

# 向量模型（DashScope 嵌入模型名）
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 检索重排序（gte-rerank，与 DASHSCOPE 同 Key；false 则仅向量召回）
RERANK_ENABLED=true
DASHSCOPE_RERANK_MODEL=gte-rerank
RERANK_CANDIDATE_MULTIPLIER=4
RERANK_MAX_CANDIDATES=40

# 兼容模式 Base URL，一般无需修改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI（LLM_PROVIDER=openai）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Claude（LLM_PROVIDER=anthropic）
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022

# 智谱 GLM（LLM_PROVIDER=glm）
# ZHIPU_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_CHAT_MODEL=glm-4

# DeepSeek（LLM_PROVIDER=deepseek）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# 逗号分隔，允许的前端来源
# 开发与 Next 对齐：浏览器用 localhost 或 127.0.0.1 打开前端时需分别放行，否则 GET /api/chat/model-options 会被 CORS 拦截，模型下拉会一直显示「默认模型」
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Docker 基础设施（docker compose up -d 后默认可用）──────────────────────
DATABASE_URL=postgresql+asyncpg://tcm:tcm_secret@127.0.0.1:5433/tcm
# 生产建议 false，仅通过 Alembic 管理表结构
DATABASE_AUTO_CREATE_TABLES=true
REDIS_URL=redis://127.0.0.1:6379/0
QDRANT_URL=http://127.0.0.1:6333

# 知识库上传：单文件最大字节数；异步入库临时目录（空则 backend/data/ingest_tmp）
MAX_UPLOAD_BYTES=52428800
INGEST_TEMP_DIR=

# 分块：目标长度、重叠、是否先按 Markdown ## 粗分章节
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=64
KNOWLEDGE_CHUNK_PRESPLIT_SECTIONS=true

# 异步入库：true 时用 Celery（需单独启动 worker，见项目根 docker compose profile worker）
CELERY_INGEST_ENABLED=true

# 已启用 MCP 的周期探测间隔（秒）；0 关闭（本地测试可设 0）
MCP_PROBE_INTERVAL_SECONDS=300

# SearXNG（docker compose up -d searxng 后默认可用；设为空可禁用 searx_web_search）
# 中文检索走后端约定的百度引擎，需在 docker/searxng/settings.yml 中启用 baidu 并重启 searxng
SEARXNG_URL=http://127.0.0.1:8888
# 默认约 10s，与 docker/searxng outgoing 一致，断网时尽快失败
# SEARXNG_TIMEOUT_SECONDS=10

# 可选：Agent 工具 search_tcm_knowledge 未指定 kb_id 时优先使用此知识库
DEFAULT_KNOWLEDGE_BASE_ID=

# ── 阿里云 OSS（可选）：聊天等多模态图片上传，`POST /api/storage/oss/chat-image` 返回临时签名 GET URL（供 VL 服务端拉图）；与 DashScope Key 分开，建议 RAM 子账号最小权限（PutObject / GetObject）
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_ENDPOINT=https://oss-cn-<region>.aliyuncs.com
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_CHAT_PREFIX=chat-uploads/
# ALIYUN_OSS_SIGN_URL_EXPIRES_SECONDS=3600
# OSS_CHAT_IMAGE_MAX_BYTES=8388608

# JWT（登录接口签发 Token；生产环境务必改为长随机串）
JWT_SECRET=dev-only-change-me-use-long-random-string
JWT_EXPIRE_MINUTES=10080

# ── OAuth（GitHub / Gitee）；回调地址须与开放平台登记一字不差（authorize 与 token 置换共用同一 REDIRECT_URI）
# FRONTEND_URL=http://localhost:3000
# 登录成功后 302 到 ${FRONTEND_URL}/login?code=... 或 thirdFlow=...（与前端登录页 OAuth 交换逻辑对齐，勿改用根路径 /）
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GitHub OAuth App：Authorization callback URL 须与下行一致（默认与常见文档一致）
# GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback
# GITEE_CLIENT_ID=
# GITEE_CLIENT_SECRET=
# GITEE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/gitee/callback

# ── 邮件（验证码）；未配置或 MAIL_SKIP_SEND=true 时仅 Redis + 日志
# MAIL_HOST=
# MAIL_PORT=465
# MAIL_USERNAME=
# MAIL_CODE=

# 可选：非空时，除 Bearer 外还需请求头 X-API-Key 与本值一致（知识库 / Agent / MCP 等管理接口）
# API_KEY=
# 若启用：前端 Next 须在 frontend/.env.local 写相同值 NEXT_PUBLIC_API_KEY=...（否则设置页增删改会 401）

# 数据库迁移（在 backend 目录执行）：
#   alembic upgrade head
# 若表已由 init_db（create_all）建好且与当前迁移一致、但 alembic_version 为空：
#   alembic stamp head
# 若仅有初始 revision 的表、需再跑后续迁移：
#   alembic stamp fe4256aec939 && alembic upgrade head
